---
interface Props {
  label: string;
  name: string;
  type?: string;
  placeholder?: string;
  required?: boolean;
  class?: string;
  id?: string;
  value?: string;
}

const { 
  label, 
  name, 
  type = 'text', 
  placeholder = '', 
  required = false, 
  class: className = '', 
  id = name,
  value = ''
} = Astro.props;
---

<div class:list={["w-full", className]}>
  <label for={id} class="block font-headline font-bold text-[10px] uppercase tracking-widest text-on-surface-variant mb-2">
    {label}
    {required && <span class="text-primary">*</span>}
  </label>
  <input 
    type={type as any} 
    name={name} 
    id={id} 
    placeholder={placeholder} 
    required={required}
    value={value}
    class="w-full bg-surface-container-low border-none border-b-2 border-outline/30 focus:border-primary focus:ring-0 font-body py-4 px-4 transition-all duration-200 placeholder:text-on-surface-variant/40"
  />
</div>
