---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Transport & Logistique - UDTL 31">
	<main class="pt-24">
		<!-- Hero Section -->
		<section class="relative h-[700px] flex items-center overflow-hidden bg-surface-container-low">
			<div class="absolute inset-0 z-0">
				<!-- Background Image with faded right side for readability -->
				<img class="w-full h-full object-cover opacity-80" alt="Logistique Transport" src="https://images.unsplash.com/photo-1586528116311-ad8ed7c159c4?q=80&w=2070&auto=format&fit=crop"/>
				<div class="absolute inset-0 bg-gradient-to-r from-background via-background/90 to-transparent"></div>
			</div>
			<div class="relative z-10 max-w-7xl mx-auto px-8 w-full">
				<div class="max-w-2xl">
					<div class="flex items-center gap-2 mb-6">
						<span class="bg-tertiary-container text-on-tertiary-container px-3 py-1 text-xs font-bold tracking-widest uppercase rounded-sm">31 - HAUTE-GARONNE / MIDI-PYRÉNÉES</span>
					</div>
					<h1 class="text-6xl md:text-7xl font-black font-headline tracking-tighter leading-[1] text-on-background mb-6">
						Conducteurs, Logisticiens : <br/>
						<span class="text-primary italic">Vos droits, Notre combat.</span>
					</h1>
					<p class="text-xl font-body text-on-surface-variant max-w-xl mb-10 leading-relaxed font-medium">
						Le secteur du transport et de la logistique est le cœur battant de notre région. FO se bat quotidiennement pour que votre engagement soit reconnu, protégé et rémunéré à sa juste valeur.
					</p>
					<div class="flex flex-wrap gap-4">
						<a href="/adhesion" class="signature-gradient text-on-primary px-8 py-4 rounded-sm font-headline font-extrabold text-[15px] flex items-center gap-3 hover:opacity-90 transition-all uppercase">
							Adhérer maintenant
							<span class="material-symbols-outlined">arrow_forward</span>
						</a>
						<button class="bg-surface-container-highest text-on-background px-8 py-4 rounded-sm font-headline font-bold text-[15px] hover:bg-surface-container-high transition-all uppercase tracking-tight">
							Nos Victoires
						</button>
					</div>
				</div>
			</div>
		</section>

		<!-- Informations Secteur Section -->
		<section class="max-w-7xl mx-auto px-8 py-24">
			<h2 class="text-4xl font-black font-headline tracking-tighter mb-4"><span class="border-b-[4px] border-primary pb-1">Inform</span>ations Secteur</h2>
			<p class="font-body text-on-surface-variant mb-12">L'essentiel de vos droits en temps réel.</p>
			
			<div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-8">
				
				<!-- Réglementations -->
				<div class="md:col-span-8 bg-surface-container-lowest border-l-4 border-primary p-10 relative custom-shadow" style="box-shadow: 0 4px 20px rgba(94, 63, 59, 0.04);">
					<div class="flex items-center gap-3 mb-6">
						<span class="material-symbols-outlined text-primary text-3xl">gavel</span>
						<h3 class="text-2xl font-black font-headline uppercase tracking-tight">Réglementations 2024</h3>
					</div>
					<p class="font-body text-on-surface-variant mb-8 leading-relaxed max-w-xl">
						Temps de conduite, repos hebdomadaire, travail de nuit : découvrez les dernières mises à jour de la convention collective des transports routiers. Ne laissez aucune infraction passer.
					</p>
					<ul class="space-y-4 mb-10">
						<li class="flex items-center gap-3 font-body font-medium text-on-surface">
							<span class="material-symbols-outlined text-primary text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
							Calcul des frais de déplacement
						</li>
						<li class="flex items-center gap-3 font-body font-medium text-on-surface">
							<span class="material-symbols-outlined text-primary text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
							Indemnités de panier revalorisées
						</li>
						<li class="flex items-center gap-3 font-body font-medium text-on-surface">
							<span class="material-symbols-outlined text-primary text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
							Sécurité sur les plateformes logistiques
						</li>
					</ul>
					<a class="text-primary font-headline font-bold uppercase text-sm tracking-wider hover:gap-2 transition-all flex items-center gap-1" href="#">
						CONSULTER LE GUIDE JURIDIQUE
					</a>
				</div>

				<!-- Grilles de salaires -->
				<div class="md:col-span-4 bg-surface-container-low p-10 flex flex-col justify-between border-t-4 border-tertiary">
					<div>
					   <span class="material-symbols-outlined text-tertiary text-3xl mb-4">payments</span>
					   <h3 class="text-xl font-black font-headline uppercase tracking-tight mb-4">Grilles de salaires</h3>
					   <p class="font-body text-sm text-on-surface-variant leading-relaxed">
						   Vérifiez si votre salaire correspond aux minima conventionnels actuels du secteur Logistique & Transport.
					   </p>
					</div>
					<div class="mt-8">
						<div class="text-4xl font-black font-headline text-tertiary mb-1">+5.4%</div>
						<div class="font-headline font-bold text-[10px] tracking-widest text-on-surface-variant uppercase">Augmentation moyenne obtenue par FO</div>
					</div>
				</div>

			</div>

			<div class="grid grid-cols-1 md:grid-cols-12 gap-8">
				<!-- Image Block -->
				<div class="md:col-span-6 relative aspect-[16/9] overflow-hidden rounded-sm">
					<img class="w-full h-full object-cover" src="https://images.unsplash.com/photo-1601584115197-04ecc0da31d7?q=80&w=2070&auto=format&fit=crop" alt="Flotte de camions sur la route"/>
					<div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent flex items-end p-8">
						<h3 class="text-white font-headline font-black text-3xl uppercase italic tracking-tighter">Sur la route avec vous</h3>
					</div>
				</div>
				
				<!-- Nos Victoires Block -->
				<div class="md:col-span-6 bg-inverse-surface text-inverse-on-surface p-10 flex items-center justify-between relative overflow-hidden rounded-sm">
					<div class="relative z-10 max-w-sm">
						<h3 class="text-3xl font-black font-headline text-primary mb-4 uppercase tracking-tighter">Nos Victoires</h3>
						<p class="font-body text-sm text-surface-dim mb-8 leading-relaxed">
							À Toulouse et dans toute la Haute-Garonne, nos délégués FO ont sécurisé des primes exceptionnelles de pouvoir d'achat pour plus de 2 500 salariés du secteur logistique.
						</p>
						<button class="bg-surface-container-lowest text-on-background px-6 py-3 rounded-sm font-headline font-bold text-xs uppercase tracking-widest hover:bg-surface-dim transition-colors">
							DÉCOUVRIR LES BILANS
						</button>
					</div>
					<!-- Tilted Red Trophy card -->
					<div class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-12 rotate-12 w-48 h-56 signature-gradient shadow-2xl flex items-center justify-center transform hover:rotate-6 transition-transform">
						<span class="material-symbols-outlined text-white text-6xl" style="font-variation-settings: 'FILL' 1;">emoji_events</span>
					</div>
				</div>
			</div>
		</section>

		<!-- Pourquoi nous rejoindre (Split section) -->
		<section class="bg-surface-container-low relative overflow-hidden">
			<div class="max-w-7xl mx-auto px-8 py-24 grid grid-cols-1 md:grid-cols-2 gap-16 relative z-10">
				<!-- Left Text -->
				<div class="flex flex-col justify-center">
					<h2 class="text-5xl font-black font-headline tracking-tighter mb-12 text-on-background leading-tight">Pourquoi nous<br/>rejoindre ?</h2>
					
					<div class="space-y-10">
						<div class="pl-6 border-l-2 border-outline-variant/40 hover:border-primary transition-colors cursor-default">
							<h4 class="font-headline font-bold text-lg mb-2 uppercase text-on-background">Protection Juridique Totale</h4>
							<p class="font-body text-on-surface-variant text-sm leading-relaxed">Bénéficiez d'une assistance spécialisée en droit du transport en cas de litige avec votre employeur.</p>
						</div>
						
						<div class="pl-6 border-l-2 border-outline-variant/40 hover:border-primary transition-colors cursor-default">
							<h4 class="font-headline font-bold text-lg mb-2 uppercase text-on-background">Indépendance Absolue</h4>
							<p class="font-body text-on-surface-variant text-sm leading-relaxed">Libre de tout parti politique et de toute religion, FO ne défend que vos intérêts professionnels.</p>
						</div>

						<div class="pl-6 border-l-2 border-outline-variant/40 hover:border-primary transition-colors cursor-default">
							<h4 class="font-headline font-bold text-lg mb-2 uppercase text-on-background">Solidarité de Proximité</h4>
							<p class="font-body text-on-surface-variant text-sm leading-relaxed">Une antenne locale en Haute-Garonne pour vous écouter, vous conseiller et agir rapidement sur le terrain.</p>
						</div>
					</div>
				</div>
				
				<!-- Right Form -->
				<div class="flex items-center justify-center pt-8">
					<div class="relative w-full max-w-md">
						<div class="absolute -inset-4 border border-outline-variant/30 hidden md:block z-0 pointer-events-none"></div>
						<!-- Form card -->
						<div class="bg-surface-container-lowest p-10 rounded-sm custom-shadow relative z-10" style="box-shadow: 0 20px 40px rgba(94, 63, 59, 0.06);">
							<h3 class="text-3xl font-black font-headline text-center mb-2 tracking-tight">Rejoindre la Force</h3>
							<p class="font-body text-on-surface-variant text-center text-sm mb-10 leading-relaxed">Remplissez le formulaire en 2 minutes pour protéger votre avenir professionnel.</p>
							
							<form class="space-y-6">
								<div>
									<label class="block font-headline font-bold text-[10px] uppercase tracking-widest text-on-surface-variant mb-2">Nom Complet</label>
									<input type="text" class="w-full bg-surface-container-low border-none border-b-2 border-outline focus:border-primary focus:ring-0 font-body py-3 px-4 transition-colors" placeholder="Jean Dupont">
								</div>
								
								<div>
									<label class="block font-headline font-bold text-[10px] uppercase tracking-widest text-on-surface-variant mb-2">Secteur d'activité</label>
									<select class="w-full bg-surface-container-low border-none border-b-2 border-outline focus:border-primary focus:ring-0 font-body py-3 px-4 transition-colors text-on-background appearance-none">
										<option>Conducteur Routier</option>
										<option>Logisticien</option>
										<option>Manutention</option>
										<option>Ambulancier</option>
										<option>Autre Secteur</option>
									</select>
								</div>

								<button type="button" class="w-full signature-gradient text-on-primary py-4 font-headline uppercase font-bold text-sm tracking-widest mt-4 hover:opacity-90 active:scale-[0.98] transition-all rounded-sm">
									Adhérer maintenant
								</button>
							</form>
						</div>
						<div class="absolute -bottom-8 -left-8 w-24 h-24 bg-surface-container-high z-0 hidden md:block pointer-events-none"></div>
					</div>
				</div>
			</div>
		</section>

		<!-- Bottom Red Banner -->
		<section class="signature-gradient text-on-primary py-16 relative overflow-hidden mb-12">
			<div class="absolute inset-0 flex items-center justify-center opacity-10 pointer-events-none mix-blend-overlay">
				<span class="font-black font-headline text-[15vw] whitespace-nowrap">FORCE OUVRIÈRE</span>
			</div>
			<div class="relative z-10 max-w-7xl mx-auto px-8 flex flex-col md:flex-row justify-between items-center gap-8">
				<h2 class="text-3xl md:text-4xl font-black font-headline italic uppercase max-w-xl leading-tight">
					FO Midi-Pyrénées : L'indépendance est notre force.
				</h2>
				<div class="flex items-center gap-12">
					<div class="text-center">
						<div class="text-5xl font-black font-headline mb-1">450+</div>
						<div class="font-headline font-bold text-[9px] uppercase tracking-widest opacity-80">Entreprises<br/>Représentées</div>
					</div>
					<div class="w-px h-16 bg-white/20"></div>
					<div class="text-center">
						<div class="text-5xl font-black font-headline mb-1">24/7</div>
						<div class="font-headline font-bold text-[9px] uppercase tracking-widest opacity-80">Veille<br/>Syndicale</div>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>
