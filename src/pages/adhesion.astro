---
import MainLayout from '../layouts/MainLayout.astro';
import Nav from '../components/ui/Nav.astro';
import Footer from '../components/ui/Footer.astro';
import Button from '../components/ui/Button.astro';
import Input from '../components/ui/Input.astro';
import Card from '../components/ui/Card.astro';
import Section from '../components/ui/Section.astro';
---

<MainLayout title="Adhésion">
    <Nav slot="nav" active="Adhésion" />
    
    <main class="pt-32">
        <!-- Hero Minimized -->
        <Section background="low" bleed={true} class="py-20 flex items-center min-h-[40vh]">
            <div class="absolute inset-0 z-0">
                <img 
                    class="w-full h-full object-cover opacity-10 grayscale mix-blend-multiply" 
                    alt="Intérieur logistique" 
                    src="https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?q=80&w=2070&auto=format&fit=crop"
                />
            </div>
            <div class="max-w-7xl mx-auto px-8 w-full relative z-10">
                <div class="max-w-4xl">
                   <h1 class="text-6xl md:text-8xl font-black font-headline tracking-tighter leading-[0.9] text-on-background mb-4">
                        REJOINDRE LA <br/> <span class="signature-gradient text-transparent bg-clip-text">FORCE.</span>
                    </h1>
                    <p class="text-lg font-body text-on-surface-variant max-w-xl leading-relaxed italic">
                        Devenez acteur de votre avenir professionnel dans le transport et la logistique.
                    </p>
                </div>
            </div>
        </Section>

        <!-- Form & Info Section -->
        <Section background="surface" class="py-32">
            <div class="flex flex-col lg:flex-row gap-20">
                
                <!-- Left: Multi-step Form -->
                <div class="w-full lg:w-7/12">
                    <Card surface="lowest" border={true} class="p-12 shadow-2xl">
                        <header class="mb-12">
                            <h2 class="text-3xl font-black font-headline uppercase tracking-tighter mb-2">Adhésion 2025</h2>
                            <p class="font-headline font-bold text-[10px] uppercase tracking-[0.2em] text-primary">Solidarité & Indépendance</p>
                        </header>

                        <!-- Step Indicator -->
                        <div class="flex items-center justify-between mb-16 px-4">
                            {[1, 2, 3].map(step => (
                                <div class="flex items-center flex-1 last:flex-none even:mx-4">
                                    <div class:list={[
                                        "w-10 h-10 flex items-center justify-center font-headline font-black text-sm rounded-sm transition-all duration-300",
                                        step === 1 ? "bg-primary text-on-primary" : "bg-surface-container-high text-on-surface-variant/40"
                                    ]} id={`step-dot-${step}`}>
                                        {step}
                                    </div>
                                    {step < 3 && <div class="h-[2px] flex-grow bg-surface-container-high mx-4 relative overflow-hidden">
                                        <div class="absolute inset-0 bg-primary/20 transition-all duration-500" id={`step-line-${step}`}></div>
                                    </div>}
                                </div>
                            ))}
                        </div>

                        <form id="membership-form" class="space-y-12">
                            
                            <!-- STEP 1: IDENTITY -->
                            <div id="step-1" class="space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-500">
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                                    <Input label="Nom de famille" name="nom" required placeholder="DUPONT" />
                                    <Input label="Prénom" name="prenom" required placeholder="Jean" />
                                </div>
                                <Input label="E-mail Personnel" name="email" type="email" required placeholder="jean.dupont@email.fr" />
                                <Input label="Téléphone" name="tel" type="tel" required placeholder="06 12 34 56 78" />
                                
                                <div class="pt-6">
                                    <Button variant="primary" class="w-full py-5 text-sm group" type="button" onclick="window.nextStep(2)">
                                        ÉTAPE SUIVANTE : EMPLOI
                                        <span class="material-symbols-outlined text-[18px] group-hover:translate-x-1 transition-transform">arrow_forward</span>
                                    </Button>
                                </div>
                            </div>

                            <!-- STEP 2: PROFESSION (Hidden by default) -->
                            <div id="step-2" class="hidden space-y-8">
                                <Input label="Entreprise / Société" name="entreprise" required placeholder="Ex: Transports 31" />
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                                    <Input label="Fonction / Poste" name="fonction" required placeholder="Chauffeur SPL" />
                                    <div class="space-y-2">
                                        <label class="block font-headline font-bold text-[10px] uppercase tracking-widest text-on-surface-variant mb-2">Type de contrat</label>
                                        <select name="contrat" class="w-full bg-surface-container-low border-none border-b-2 border-outline/30 focus:border-primary focus:ring-0 font-body py-4 px-4 transition-all mb-8">
                                            <option>CDI</option>
                                            <option>CDD</option>
                                            <option>Intérim</option>
                                            <option>Apprentissage</option>
                                        </select>
                                    </div>
                                    <div class="space-y-2">
                                        <label class="block font-headline font-bold text-[10px] uppercase tracking-widest text-on-surface-variant mb-2">Temps de travail</label>
                                        <select name="temps" class="w-full bg-surface-container-low border-none border-b-2 border-outline/30 focus:border-primary focus:ring-0 font-body py-4 px-4 transition-all">
                                            <option>Temps Plein</option>
                                            <option>Temps Partiel</option>
                                        </select>
                                    </div>
                                </div>
                                
                                <div class="flex gap-4 pt-6">
                                    <Button variant="secondary" class="w-1/3" type="button" onclick="window.prevStep(1)">Retour</Button>
                                    <Button variant="primary" class="flex-grow group" type="button" onclick="window.nextStep(3)">
                                        ÉTAPE SUIVANTE : COTISATION
                                        <span class="material-symbols-outlined text-[18px] group-hover:translate-x-1 transition-transform">arrow_forward</span>
                                    </Button>
                                </div>
                            </div>

                            <!-- STEP 3: COTISATION -->
                            <div id="step-3" class="hidden space-y-10">
                                <Card surface="low" class="p-8 border-l-4 border-primary">
                                    <div class="flex justify-between items-start mb-6">
                                        <div>
                                            <p class="font-headline font-black text-4xl text-on-background">137,00 €</p>
                                            <p class="font-headline font-bold text-[9px] uppercase tracking-[0.3em] text-primary">Cotisation Annuelle 2025</p>
                                        </div>
                                        <span class="material-symbols-outlined text-5xl opacity-10">verified_user</span>
                                    </div>
                                    <div class="space-y-4">
                                        <div class="flex items-center gap-4 bg-background/50 p-4 rounded-sm">
                                            <span class="material-symbols-outlined text-primary text-2xl">savings</span>
                                            <p class="font-body text-xs text-on-surface-variant">
                                                <strong>Avantage Fiscal de 66%</strong> : votre adhésion ne vous coûte réellement que <strong>3,88 € / mois</strong> après déduction.
                                            </p>
                                        </div>
                                    </div>
                                </Card>

                                <label class="flex items-start gap-4 cursor-pointer group">
                                    <input type="checkbox" required class="mt-1 w-5 h-5 rounded-sm border-outline/30 text-primary focus:ring-primary/20" />
                                    <span class="font-body text-[11px] text-on-surface-variant leading-relaxed">
                                        J'accepte d'adhérer à l'UDTL 31 et je certifie l'exactitude des informations fournies. Conformément au RGPD, mes données ne seront jamais cédées à des tiers.
                                    </span>
                                </label>

                                <div class="flex gap-4 pt-4">
                                    <Button variant="secondary" class="w-1/3" type="button" onclick="window.prevStep(2)">Retour</Button>
                                    <Button variant="signature" class="flex-grow py-5 text-sm" type="submit" id="submit-btn">
                                        FINALISER MON ADHÉSION
                                    </Button>
                                </div>
                            </div>

                            <!-- HIDDEN FIELDS -->
                            <input type="hidden" name="cotisation" value="137" />
                            <input type="hidden" name="frequence" value="annuelle" />
                        </form>
                    </Card>
                </div>

                <!-- Right: Content -->
                <div class="w-full lg:w-5/12 space-y-16">
                    <div class="space-y-6">
                        <h3 class="text-3xl font-black font-headline uppercase tracking-tighter border-l-8 border-primary pl-10">POURQUOI<br/>ADHÉRER ?</h3>
                        <div class="space-y-8 font-body text-on-surface-variant leading-relaxed">
                            <div class="flex gap-6">
                                <span class="material-symbols-outlined text-primary text-3xl shrink-0">shield_with_heart</span>
                                <p><strong>Protection Juridique</strong> : assistance et défense de vos intérêts devant les Prud'hommes en cas de litige.</p>
                            </div>
                            <div class="flex gap-6">
                                <span class="material-symbols-outlined text-primary text-3xl shrink-0">groups</span>
                                <p><strong>Solidarité</strong> : rejoignez un collectif de 1500 militants en Haute-Garonne pour ne plus être isolé.</p>
                            </div>
                            <div class="flex gap-6">
                                <span class="material-symbols-outlined text-primary text-3xl shrink-0">campaign</span>
                                <p><strong>Influence</strong> : participez à nos commissions de branche et pesez sur les décisions nationales.</p>
                            </div>
                        </div>
                    </div>

                    <Card surface="high" class="p-10 border border-on-background/5">
                        <h4 class="font-headline font-bold text-sm uppercase tracking-widest mb-4">Une question ?</h4>
                        <p class="font-body text-sm text-on-surface-variant mb-8 leading-relaxed italic">
                            Nos délégués départementaux vous répondent en toute discrétion.
                        </p>
                        <a href="tel:0561000000" class="text-4xl font-headline font-black text-primary tracking-tighter hover:scale-105 transition-transform inline-block">
                            05 61 00 00 00
                        </a>
                    </Card>
                </div>
            </div>
        </Section>
    </main>

    <Footer slot="footer" />
</MainLayout>

<!-- STEPPING SCRIPT -->
<script is:inline>
    window.nextStep = (step) => {
        const prevStep = step - 1;
        // Basic validation
        const fields = document.querySelector(`#step-${prevStep}`).querySelectorAll('input[required]');
        let valid = true;
        fields.forEach(f => {
            if(!f.value) {
                f.classList.add('border-primary', 'bg-primary/5');
                valid = false;
            } else {
                f.classList.remove('border-primary', 'bg-primary/5');
            }
        });
        if(!valid) return;

        // Transitions
        document.querySelector(`#step-${prevStep}`).classList.add('hidden');
        const next = document.querySelector(`#step-${step}`);
        next.classList.remove('hidden');
        next.classList.add('animate-in', 'fade-in', 'slide-in-from-bottom-4', 'duration-500');

        // Indicators
        document.querySelector(`#step-dot-${step}`).classList.replace('bg-surface-container-high', 'bg-primary');
        document.querySelector(`#step-dot-${step}`).classList.replace('text-on-surface-variant/40', 'text-on-primary');
        if(document.querySelector(`#step-line-${prevStep}`)) {
            document.querySelector(`#step-line-${prevStep}`).classList.replace('bg-primary/20', 'bg-primary');
        }
        
        window.scrollTo({ top: document.querySelector('#membership-form').offsetTop - 200, behavior: 'smooth' });
    };

    window.prevStep = (step) => {
        const current = step + 1;
        document.querySelector(`#step-${current}`).classList.add('hidden');
        document.querySelector(`#step-${step}`).classList.remove('hidden');

        // Indicators revert
        document.querySelector(`#step-dot-${current}`).classList.replace('bg-primary', 'bg-surface-container-high');
        document.querySelector(`#step-dot-${current}`).classList.replace('text-on-primary', 'text-on-surface-variant/40');
        if(document.querySelector(`#step-line-${step}`)) {
            document.querySelector(`#step-line-${step}`).classList.replace('bg-primary', 'bg-primary/20');
        }
    };

    // SUBMISSION LOGIC
    document.getElementById('membership-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('submit-btn');
        const originalText = btn.innerText;
        btn.disabled = true;
        btn.innerText = "ENVOI EN COURS...";
        
        const data = Object.fromEntries(new FormData(e.target));
        
        try {
            const response = await fetch('/api/handle-adhesion', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await response.json();
            if(result.success) {
                window.location.href = '/merci/';
            } else {
                throw new Error(result.error);
            }
        } catch (err) {
            btn.disabled = false;
            btn.innerText = "ERREUR - RÉESSAYER";
            alert("Une erreur est survenue lors de l'envoi : " + err.message);
        }
    });
</script>
