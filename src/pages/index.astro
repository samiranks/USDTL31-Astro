---
import MainLayout from '../layouts/MainLayout.astro';
import Nav from '../components/ui/Nav.astro';
import Footer from '../components/ui/Footer.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import Section from '../components/ui/Section.astro';
---

<MainLayout title="Accueil">
    <Nav slot="nav" active="Accueil" />
    
    <main>
        <!-- HERO SECTION -->
        <Section background="low" bleed={true} class="min-h-[85vh] flex items-end pt-32 pb-20">
            <div class="absolute inset-0 z-0">
                <img 
                    class="w-full h-full object-cover grayscale opacity-40 mix-blend-multiply" 
                    alt="Vue panoramique de Toulouse" 
                    src="https://images.unsplash.com/photo-1519003722824-194d4455a60c?q=80&w=2075&auto=format&fit=crop"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-background via-background/60 to-transparent"></div>
            </div>
            
            <div class="relative z-10 max-w-7xl mx-auto px-8 w-full">
                <div class="max-w-4xl">
                    <div class="flex items-center gap-4 mb-8">
                        <span class="bg-primary text-on-primary px-4 py-1 text-[10px] font-headline font-bold uppercase tracking-[0.3em]">31 - HAUTE-GARONNE</span>
                        <div class="h-px flex-grow bg-outline-variant/30"></div>
                    </div>
                    
                    <h1 class="text-7xl md:text-9xl font-black font-headline tracking-tighter leading-[0.85] text-on-background mb-10 text-balanced">
                        LE BASTION <br/> 
                        <span class="signature-gradient text-transparent bg-clip-text italic">OCCITAN.</span>
                    </h1>
                    
                    <p class="text-xl md:text-2xl font-body text-on-surface-variant max-w-2xl mb-12 leading-relaxed font-light">
                        L'UDTL 31 défend les droits des travailleurs du transport et de la logistique. Force, indépendance et solidarité régionale au cœur de la Ville Rose.
                    </p>
                    
                    <div class="flex flex-wrap gap-6">
                        <Button variant="signature" class="px-10 py-5 text-sm" onclick="location.href='/activites'">
                            DÉCOUVRIR NOS ACTIONS
                            <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                        </Button>
                        <Button variant="tertiary" class="px-6 text-[11px]" onclick="location.href='/adhesion'">
                            Rejoindre le syndicat
                        </Button>
                    </div>
                </div>
            </div>
        </Section>

        <!-- BENTO NEWS SECTION -->
        <Section background="surface">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-10">
                <!-- Main News -->
                <Card surface="low" class="md:col-span-8 p-12 group overflow-hidden border" border={true}>
                    <div class="relative z-10 space-y-6">
                        <header class="flex justify-between items-start">
                            <span class="text-primary font-headline font-bold uppercase tracking-widest text-[10px]">Actualités 2025</span>
                            <span class="text-on-surface-variant/40 font-body text-[10px] uppercase font-bold">12 Mars 2025</span>
                        </header>
                        <h2 class="text-4xl md:text-5xl font-black font-headline tracking-tight leading-none group-hover:text-primary transition-colors">
                            Négociations Annuelles : L'UDTL 31 maintient la pression.
                        </h2>
                        <p class="text-on-surface-variant font-body text-lg leading-relaxed max-w-xl">
                            Face à l'inflation et aux enjeux énergétiques, nous exigeons une revalorisation immédiate des grilles salariales pour tous les chauffeurs de la région Occitanie.
                        </p>
                        <Button variant="tertiary" class="p-0 text-xs">Lire la suite</Button>
                    </div>
                </Card>

                <!-- Action Card -->
                <Card surface="high" class="md:col-span-4 p-10 bg-primary text-on-primary flex flex-col justify-between">
                    <span class="material-symbols-outlined text-5xl opacity-40">gavel</span>
                    <div>
                        <h3 class="text-3xl font-black font-headline mb-4 uppercase tracking-tighter">DROIT DU TRAVAIL</h3>
                        <p class="font-body text-sm opacity-80 mb-8 leading-relaxed">Besoin d'un conseil juridique ? Nos experts reçoivent gratuitement nos adhérents chaque mardi.</p>
                        <Button variant="secondary" class="w-full bg-on-background text-background hover:bg-background hover:text-on-background">PRENDRE RDV</Button>
                    </div>
                </Card>

                <!-- Quick Services -->
                <Card surface="low" class="md:col-span-4 p-10">
                    <h4 class="font-headline font-bold text-sm uppercase tracking-widest mb-10 text-primary">Branches</h4>
                    <ul class="space-y-6">
                        {['Transport Routier', 'Logistique & Entrepôts', 'Messagerie', 'Ambulances'].map(item => (
                            <li class="flex items-center justify-between group cursor-pointer pb-4 border-b border-outline-variant/10">
                                <span class="font-headline font-bold text-[11px] uppercase tracking-widest">{item}</span>
                                <span class="material-symbols-outlined text-primary group-hover:translate-x-2 transition-transform">trending_flat</span>
                            </li>
                        ))}
                    </ul>
                </Card>

                <Card surface="highest" class="md:col-span-8 p-12 flex items-center justify-center relative overflow-hidden">
                    <div class="relative z-10 text-center space-y-4">
                        <div class="text-6xl md:text-8xl font-black font-headline tracking-tighter text-on-background">1500+</div>
                        <div class="font-headline font-bold text-[10px] uppercase tracking-[0.4em] text-primary">Militants en Haute-Garonne</div>
                    </div>
                    <span class="absolute -bottom-10 -right-10 text-[20rem] font-black font-headline opacity-[0.03] select-none">31</span>
                </Card>
            </div>
        </Section>

        <!-- EDITORIAL ENGAGEMENT -->
        <Section background="low">
            <div class="flex flex-col md:flex-row gap-20 lg:gap-32 items-center">
                <div class="w-full md:w-5/12 relative">
                    <div class="aspect-[4/5] bg-on-background relative z-10 group overflow-hidden shadow-2xl">
                        <img 
                            class="w-full h-full object-cover grayscale opacity-70 group-hover:scale-110 transition-transform duration-700" 
                            alt="Délégué UDTL 31 sur le terrain" 
                            src="https://images.unsplash.com/photo-1541888941259-7b9f9227feae?q=80&w=2070&auto=format&fit=crop"
                        />
                        <div class="absolute inset-0 bg-primary/20 mix-blend-overlay"></div>
                    </div>
                    <!-- Overlapping signature element -->
                    <div class="absolute -bottom-10 -right-10 w-48 h-48 signature-gradient p-10 flex items-center justify-center z-20 shadow-xl rotate-3 scale-110">
                        <span class="text-on-primary font-headline font-black text-center text-xs leading-tight uppercase tracking-widest">FORCE<br/>OUVRIÈRE</span>
                    </div>
                </div>
                
                <div class="w-full md:w-7/12 space-y-10">
                    <div class="space-y-4">
                        <span class="text-primary font-headline font-bold text-[10px] tracking-[0.3em] uppercase block">Engagement</span>
                        <h2 class="text-5xl md:text-7xl font-black font-headline tracking-tighter leading-[0.95] text-on-background">
                            INDÉPENDANCE.<br/>
                            <span class="italic text-on-surface-variant font-light">Notre seule boussole.</span>
                        </h2>
                    </div>
                    
                    <div class="space-y-6 text-on-surface-variant font-body text-lg leading-relaxed max-w-xl">
                        <p>
                            À l'UDTL 31, nous ne recevons d'ordres d'aucun parti, aucune religion, aucun gouvernement. 
                            Cette indépendance absolue est le socle de notre légitimité pour défendre sans compromis les intérêts des salariés.
                        </p>
                        <p class="font-normal text-on-background italic border-l-4 border-primary pl-6">
                            "Nous sommes les gardiens du droit du travail dans le bassin toulousain, du volant jusqu'à l'entrepôt."
                        </p>
                    </div>
                    
                    <Button variant="primary" class="rounded-none px-12 group">
                        NOTRE CHARTE ÉTHIQUE
                        <span class="material-symbols-outlined text-[18px] group-hover:rotate-45 transition-transform">file_download</span>
                    </Button>
                </div>
            </div>
        </Section>

        <!-- CTA SECTION -->
        <Section background="signature" class="text-center py-32">
            <h2 class="text-5xl md:text-8xl font-black font-headline italic uppercase tracking-tighter leading-[0.8] mb-16 text-balanced">
                SEUL ON VA PLUS VITE,<br/>
                ENSEMBLE ON VA <span class="text-background underline decoration-background/30 underline-offset-[12px]">PLUS LOIN.</span>
            </h2>
            <Button variant="secondary" class="bg-background text-primary px-12 py-6 text-lg hover:bg-on-background hover:text-background" onclick="location.href='/adhesion'">
                ADHÉRER MAINTENANT
            </Button>
        </Section>
    </main>

    <Footer slot="footer" />
</MainLayout>

<style>
    h1, h2, h3 {
        text-shadow: 0 0 40px rgba(0,0,0,0.05);
    }
</style>
