---
import MainLayout from '../layouts/MainLayout.astro';
import Nav from '../components/ui/Nav.astro';
import Footer from '../components/ui/Footer.astro';
import Section from '../components/ui/Section.astro';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('activites');
const sortedArticles = allArticles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = ["Toutes", "Négociations", "Juridique", "Grèves & Mouvements", "Actualité Générale"];
---

<MainLayout title="Activités">
    <Nav slot="nav" active="Activités" />
    
    <main class="pt-32">
        <!-- Hero Header -->
        <Section background="low" bleed={true} class="py-24 border-b border-outline-variant/10">
            <div class="max-w-7xl mx-auto px-8">
                <div class="flex items-center gap-4 mb-8">
                    <span class="text-primary font-headline font-bold text-[10px] tracking-[0.4em] uppercase">SUR LE TERRAIN</span>
                    <div class="h-px flex-grow bg-outline-variant/20"></div>
                </div>
                <h1 class="text-6xl md:text-9xl font-black font-headline tracking-tighter leading-[0.8] text-on-background mb-10">
                    ACTIONS & <br/> <span class="signature-gradient text-transparent bg-clip-text italic">RÉSULTATS.</span>
                </h1>
                <p class="text-xl font-body text-on-surface-variant max-w-2xl leading-relaxed font-light">
                    Retrouvez l'historique de nos combats syndicaux en Haute-Garonne. Une transparence totale sur nos négociations et nos victoires.
                </p>
            </div>
        </Section>

        <!-- Filter Bar -->
        <div class="sticky top-16 z-30 bg-surface/80 backdrop-blur-md border-b border-outline-variant/10">
            <div class="max-w-7xl mx-auto px-8 overflow-x-auto no-scrollbar py-4 flex gap-8 items-center">
                <span class="font-headline font-bold text-[9px] uppercase tracking-widest text-on-surface-variant/50 shrink-0">Filtrer par :</span>
                {categories.map(cat => (
                    <button 
                        class:list={[
                            "px-4 py-2 font-headline font-bold text-[10px] uppercase tracking-widest transition-all hover:text-primary whitespace-nowrap filter-btn",
                            cat === "Toutes" ? "text-primary border-b-2 border-primary" : "text-on-surface-variant"
                        ]}
                        data-category={cat}
                    >
                        {cat}
                    </button>
                ))}
            </div>
        </div>

        <!-- Grid -->
        <Section background="surface" class="py-24 min-h-[60vh]">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12" id="articles-grid">
                {sortedArticles.map(article => (
                    <div class="article-card group" data-cat={article.data.category}>
                        <Card surface="low" border={true} class="h-full flex flex-col p-0 overflow-hidden hover:translate-y-[-8px] transition-all duration-500">
                            <div class="aspect-video relative overflow-hidden bg-on-background/5">
                                <img 
                                    src={article.data.image || 'https://images.unsplash.com/photo-1541888941259-7b9f9227feae?q=80&w=2070&auto=format&fit=crop'} 
                                    alt={article.data.title}
                                    class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 hover:scale-110"
                                />
                                <div class="absolute top-4 right-4 bg-primary text-on-primary px-3 py-1 font-headline font-bold text-[9px] uppercase tracking-widest">
                                    {article.data.category}
                                </div>
                            </div>
                            <div class="p-8 flex flex-col flex-grow">
                                <span class="font-body text-[10px] font-bold text-on-surface-variant/40 uppercase mb-4 tracking-tighter">
                                     {new Date(article.data.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
                                </span>
                                <h3 class="text-2xl font-black font-headline tracking-tighter leading-tight mb-4 group-hover:text-primary transition-colors">
                                    {article.data.title}
                                </h3>
                                <p class="text-sm font-body text-on-surface-variant leading-relaxed mb-10 flex-grow opacity-80">
                                    {article.data.summary}
                                </p>
                                <Button variant="tertiary" class="p-0 text-[10px] w-fit border-b border-on-background/20 group-hover:border-primary" onclick={`location.href='/activites/${article.id}'`}>
                                    LIRE L'ARTICLE 
                                    <span class="material-symbols-outlined text-[16px] group-hover:translate-x-1 transition-transform">trending_flat</span>
                                </Button>
                            </div>
                        </Card>
                    </div>
                ))}
            </div>

            <!-- Empty State -->
            <div id="empty-state" class="hidden text-center py-40 animate-in fade-in zoom-in duration-300">
                <span class="material-symbols-outlined text-8xl text-on-background/10 mb-8">tab_unselected</span>
                <p class="font-headline font-bold text-lg text-on-surface-variant italic">Aucun article trouvé dans cette catégorie.</p>
            </div>
        </Section>
    </main>

    <Footer slot="footer" />
</MainLayout>

<script is:inline>
    const btns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.article-card');
    const grid = document.getElementById('articles-grid');
    const empty = document.getElementById('empty-state');

    btns.forEach(btn => {
        btn.addEventListener('click', () => {
            const cat = btn.getAttribute('data-category');
            
            // UI Update
            btns.forEach(b => b.classList.remove('text-primary', 'border-b-2', 'border-primary'));
            btn.classList.add('text-primary', 'border-b-2', 'border-primary');

            // Filtering
            let visible = 0;
            cards.forEach(card => {
                const cardCat = card.getAttribute('data-cat');
                if(cat === "Toutes" || cardCat === cat) {
                    card.style.display = 'block';
                    visible++;
                } else {
                    card.style.display = 'none';
                }
            });

            // Empty state
            if(visible === 0) {
                grid.classList.add('hidden');
                empty.classList.remove('hidden');
            } else {
                grid.classList.remove('hidden');
                empty.classList.add('hidden');
            }
        });
    });
</script>
