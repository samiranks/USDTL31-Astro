---
import MainLayout from '../layouts/MainLayout.astro';
import Nav from '../components/ui/Nav.astro';
import Footer from '../components/ui/Footer.astro';
import Button from '../components/ui/Button.astro';
import Section from '../components/ui/Section.astro';
---

<MainLayout title="Merci">
    <Nav slot="nav" />
    
    <main class="pt-32 min-h-[70vh] flex items-center">
        <Section background="surface" class="text-center">
            <div class="max-w-2xl mx-auto space-y-12">
                <div class="inline-flex items-center justify-center w-24 h-24 rounded-full bg-primary/10 text-primary mb-8 animate-bounce">
                    <span class="material-symbols-outlined text-5xl">check_circle</span>
                </div>
                
                <h1 class="text-5xl md:text-7xl font-black font-headline tracking-tighter leading-none text-on-background">
                    MERCI POUR VOTRE <br/> <span class="signature-gradient text-transparent bg-clip-text">ENGAGEMENT.</span>
                </h1>
                
                <p class="text-xl font-body text-on-surface-variant leading-relaxed px-4">
                    Votre demande d'adhésion a été transmise avec succès à l'UDTL 31. Un délégué départemental prendra contact avec vous très prochainement.
                </p>
                
                <div class="pt-10">
                    <Button variant="primary" class="px-12" onclick="location.href='/'">
                        RETOUR À L'ACCUEIL
                    </Button>
                </div>
            </div>
        </Section>
    </main>

    <Footer slot="footer" />
</MainLayout>
