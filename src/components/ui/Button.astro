---
interface Props {
  variant?: 'primary' | 'secondary' | 'tertiary' | 'signature';
  type?: 'button' | 'submit';
  class?: string;
  onclick?: string;
  id?: string;
}

const { 
  variant = 'primary', 
  type = 'button', 
  class: className = '', 
  onclick,
  id
} = Astro.props;

const variants = {
  primary: 'bg-on-background text-background hover:bg-primary',
  secondary: 'bg-surface-container-high text-on-surface-variant hover:bg-surface-container-highest',
  tertiary: 'bg-transparent text-primary hover:text-primary-container underline underline-offset-4 decoration-2 decoration-primary/20 hover:decoration-primary/60',
  signature: 'signature-gradient text-on-primary hover:opacity-90 shadow-sm'
};

const baseClasses = "inline-flex items-center justify-center gap-2 px-6 py-4 font-headline uppercase font-bold text-[13px] tracking-widest transition-all duration-200 active:scale-[0.98] rounded-sm disabled:opacity-50 disabled:cursor-not-allowed";
---

<button 
  type={type} 
  class:list={[baseClasses, variants[variant], className]} 
  onclick={onclick}
  id={id}
>
  <slot />
</button>
